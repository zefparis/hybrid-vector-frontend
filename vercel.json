{
  "rewrites": [{ "source": "/(.*)", "destination": "/" }],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOW-FROM https://hybrid-hmh.affectli.com"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://*.affectli.com"
        }
      ]
    }
  ]
}
